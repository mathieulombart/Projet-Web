{% extends 'base.html.twig' %}

{% block title %}AlloStage – Offres postulées{% endblock %}

{% block styles %}
<style>
  html {
    scroll-behavior: smooth;
  }
  body {
    background: #f8f9ff;
  }

  .offer-card {
    border-radius: 20px;
    border: none;
    box-shadow: 0 4px 20px rgba(13, 110, 253, 0.09);
    background: #fff;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .offer-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 16px 40px rgba(13, 110, 253, 0.18);
    color: inherit;
  }

  .offer-icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .tag {
    background: #e7f0ff;
    color: #0d6efd;
    border-radius: 20px;
    padding: 3px 12px;
    font-size: 0.78rem;
    font-weight: 600;
    display: inline-block;
  }

  .timeline {
    display: flex;
    gap: 0;
    margin-top: 14px;
  }
  .timeline-step {
    flex: 1;
    text-align: center;
    position: relative;
    font-size: 0.72rem;
    color: #adb5bd;
  }
  .timeline-step.done {
    color: #0d6efd;
  }
  .timeline-step.active {
    color: #198754;
    font-weight: 700;
  }
  .timeline-step::before {
    content: "";
    display: block;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #dee2e6;
    margin: 0 auto 4px;
  }
  .timeline-step.done::before {
    background: #0d6efd;
  }
  .timeline-step.active::before {
    background: #198754;
  }
  .timeline-step:not(:last-child)::after {
    content: "";
    position: absolute;
    top: 5px;
    left: calc(50% + 6px);
    width: calc(100% - 12px);
    height: 2px;
    background: #dee2e6;
  }
  .timeline-step.done:not(:last-child)::after {
    background: #0d6efd;
  }
</style>
{% endblock %}

{% block body %}

<section class="container text-center py-5">
  <h1 class="display-6 fw-semibold text-primary">📋 Offres postulées</h1>
  <p class="text-muted">Suivez l'avancement de vos candidatures en temps réel.</p>
</section>

<section class="container pb-5">

  <div class="d-flex align-items-center justify-content-between mb-4">
    <span class="text-muted fw-semibold">2 candidatures en cours</span>
  </div>

  <div class="d-flex flex-column gap-4">

    <!-- Candidature 1 -->
    <div class="offer-card card p-4">
      <div class="d-flex align-items-center justify-content-between gap-3 flex-wrap">
        <div class="d-flex align-items-center gap-3">
          <div>
            <h5 class="fw-bold mb-1">Stage DevOps</h5>
            <div class="d-flex align-items-center gap-2 flex-wrap">
              <span class="text-muted">Capgemini</span>
              <span class="text-muted">·</span>
              <span class="text-muted">📍 Paris</span>
              <span class="tag">Stage 6 mois</span>
            </div>
          </div>
        </div>

        <span class="badge bg-warning text-dark rounded-pill px-3 py-2">En attente</span>
      </div>

      <div class="mt-3 d-flex gap-2">
        <a href="#" class="btn btn-sm btn-outline-primary rounded-pill">Voir l'offre</a>
        <a href="#" class="btn btn-sm btn-outline-secondary rounded-pill">Retirer</a>
      </div>
    </div>

    <!-- Candidature 2 -->
    <div class="offer-card card p-4">
      <div class="d-flex align-items-center justify-content-between gap-3 flex-wrap">
        <div class="d-flex align-items-center gap-3">
          <div>
            <h5 class="fw-bold mb-1">Stage Cybersécurité</h5>
            <div class="d-flex align-items-center gap-2 flex-wrap">
              <span class="text-muted">Thales</span>
              <span class="text-muted">·</span>
              <span class="text-muted">📍 Toulouse</span>
              <span class="tag">Stage 6 mois</span>
            </div>
          </div>
        </div>

        <span class="badge bg-info text-dark rounded-pill px-3 py-2">Entretien planifié</span>
      </div>

      <div class="mt-3 d-flex gap-2">
        <a href="#" class="btn btn-sm btn-outline-primary rounded-pill">Voir l'offre</a>
        <a href="#" class="btn btn-sm btn-outline-secondary rounded-pill">Retirer</a>
      </div>
    </div>

  </div>

  <div class="text-center mt-5">
    <a href="/profil" class="btn btn-outline-primary rounded-pill px-5">← Retour au profil</a>
  </div>

</section>

{% endblock %}
