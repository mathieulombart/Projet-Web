{% extends 'base.html.twig' %}

{% block title %}AlloStage – Offres postulées{% endblock %}

{% block body %}

<section class="container text-center py-5">
  <h1 class="display-6 fw-semibold text-primary">📋 Offres postulées</h1>
  <p class="text-muted">Suivez l'avancement de vos candidatures en temps réel.</p>
</section>

<section class="container pb-5">

  <div class="d-flex align-items-center justify-content-between mb-4">
    <span class="text-muted fw-semibold">2 candidatures en cours</span>
  </div>

  <div class="d-flex flex-column gap-4">

    <!-- Candidature 1 -->
    <div class="card border-0 shadow-sm rounded-4 p-4">
      <div class="d-flex align-items-center justify-content-between gap-3 flex-wrap">
        <div>
          <h5 class="fw-bold mb-1">Stage DevOps</h5>
          <div class="d-flex align-items-center gap-2 flex-wrap">
            <span class="text-muted">Capgemini</span>
            <span class="text-muted">·</span>
            <span class="text-muted">📍 Paris</span>
            <span class="badge text-bg-primary rounded-pill">Stage 6 mois</span>
          </div>
        </div>
        <span class="badge bg-warning text-dark rounded-pill px-3 py-2">En attente</span>
      </div>

      <!-- Progression steps -->
      <div class="mt-3">
        <div class="d-flex text-center">
          <div class="flex-fill">
            <div class="rounded-circle bg-primary mx-auto mb-1" style="width:12px;height:12px"></div>
            <small class="text-primary fw-semibold">Postulé</small>
          </div>
          <div class="flex-fill">
            <div class="rounded-circle bg-warning mx-auto mb-1" style="width:12px;height:12px"></div>
            <small class="text-warning fw-semibold">En attente</small>
          </div>
          <div class="flex-fill">
            <div class="rounded-circle bg-secondary mx-auto mb-1" style="width:12px;height:12px"></div>
            <small class="text-muted">Entretien</small>
          </div>
          <div class="flex-fill">
            <div class="rounded-circle bg-secondary mx-auto mb-1" style="width:12px;height:12px"></div>
            <small class="text-muted">Décision</small>
          </div>
        </div>
        <div class="progress mt-2" style="height:4px">
          <div class="progress-bar bg-warning" style="width:40%"></div>
        </div>
      </div>

      <div class="mt-3 d-flex gap-2">
        <a href="#" class="btn btn-sm btn-outline-primary rounded-pill">Voir l'offre</a>
        <a href="#" class="btn btn-sm btn-outline-secondary rounded-pill">Retirer</a>
      </div>
    </div>

    <!-- Candidature 2 -->
    <div class="card border-0 shadow-sm rounded-4 p-4">
      <div class="d-flex align-items-center justify-content-between gap-3 flex-wrap">
        <div>
          <h5 class="fw-bold mb-1">Stage Cybersécurité</h5>
          <div class="d-flex align-items-center gap-2 flex-wrap">
            <span class="text-muted">Thales</span>
            <span class="text-muted">·</span>
            <span class="text-muted">📍 Toulouse</span>
            <span class="badge text-bg-primary rounded-pill">Stage 6 mois</span>
          </div>
        </div>
        <span class="badge bg-info text-dark rounded-pill px-3 py-2">Entretien planifié</span>
      </div>

      <!-- Progression steps -->
      <div class="mt-3">
        <div class="d-flex text-center">
          <div class="flex-fill">
            <div class="rounded-circle bg-primary mx-auto mb-1" style="width:12px;height:12px"></div>
            <small class="text-primary fw-semibold">Postulé</small>
          </div>
          <div class="flex-fill">
            <div class="rounded-circle bg-primary mx-auto mb-1" style="width:12px;height:12px"></div>
            <small class="text-primary fw-semibold">En attente</small>
          </div>
          <div class="flex-fill">
            <div class="rounded-circle bg-info mx-auto mb-1" style="width:12px;height:12px"></div>
            <small class="text-info fw-semibold">Entretien</small>
          </div>
          <div class="flex-fill">
            <div class="rounded-circle bg-secondary mx-auto mb-1" style="width:12px;height:12px"></div>
            <small class="text-muted">Décision</small>
          </div>
        </div>
        <div class="progress mt-2" style="height:4px">
          <div class="progress-bar bg-info" style="width:70%"></div>
        </div>
      </div>

      <div class="mt-3 d-flex gap-2">
        <a href="#" class="btn btn-sm btn-outline-primary rounded-pill">Voir l'offre</a>
        <a href="#" class="btn btn-sm btn-outline-secondary rounded-pill">Retirer</a>
      </div>
    </div>

  </div>

  <div class="text-center mt-5">
    <a href="?page=profil" class="btn btn-outline-primary rounded-pill px-5">← Retour au profil</a>
  </div>

</section>

{% endblock %}
