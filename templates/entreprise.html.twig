{% extends 'base.html.twig' %}

{% block title %}AlloStage – Entreprises{% endblock %}

{% block body %}

<section class="container text-center py-5">
  <h1 class="display-5 fw-semibold text-primary">
    Nos entreprises partenaires
  </h1>
  <p class="lead text-muted mt-2">
    Découvrez les entreprises qui recrutent des stagiaires et alternants.
  </p>
</section>

<section class="container mb-5">
  <div class="d-flex flex-column flex-md-row gap-3 align-items-center mb-3">
    <input
      type="text"
      class="form-control rounded-pill px-4"
      placeholder="Rechercher une entreprise, un secteur…"
    />
    <a href="#" class="btn btn-primary rounded-pill px-4">Rechercher</a>
  </div>

  <div class="d-flex flex-wrap gap-2">
    {% for filtre in filtres %}
      <button class="btn {{ loop.first ? 'btn-primary' : 'btn-outline-secondary' }} rounded-pill px-3">
        {{ filtre }}
      </button>
    {% endfor %}
  </div>
</section>

<section class="container pb-5">
  <h2 class="text-primary fw-semibold mb-4">Entreprises récentes</h2>

  <div class="row g-4">
    {% for entreprise in entreprises %}
    <div class="col-12 col-md-6 col-lg-4">
      <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="bg-{{ entreprise.couleur }}" style="height:72px"></div>
        <div class="p-4 pt-2">
          <h5 class="fw-bold mb-1">{{ entreprise.nom }}</h5>
          <p class="text-muted small mb-2">
            📍 {{ entreprise.ville }} · <span class="badge text-bg-{{ entreprise.couleur }} rounded-pill">{{ entreprise.secteur }}</span>
          </p>
          <p class="text-muted small mb-3">{{ entreprise.description }}</p>
          <div class="d-flex align-items-center justify-content-between">
            <span class="badge bg-primary rounded-pill">{{ entreprise.nb_offres }} offres</span>
            <a href="#" class="btn btn-outline-primary btn-sm rounded-pill px-3">Voir les offres</a>
          </div>
        </div>
      </div>
    </div>
    {% endfor %}
  </div>

<div class="d-flex justify-content-center mt-5">
  <nav>
    <ul class="pagination">

      <li class="page-item {{ pageCourante == 1 ? 'disabled' : '' }}">
        <a class="page-link" href="?page=entreprise&p={{ pageCourante - 1 }}">Précédent</a>
      </li>

      {% for i in 1..totalPages %}
        <li class="page-item {{ i == pageCourante ? 'active' : '' }}">
          <a class="page-link" href="?page=entreprise&p={{ i }}">{{ i }}</a>
        </li>
      {% endfor %}

      <li class="page-item {{ pageCourante == totalPages ? 'disabled' : '' }}">
        <a class="page-link" href="?page=entreprise&p={{ pageCourante + 1 }}">Suivant</a>
      </li>

    </ul>
  </nav>
</div>

</section>
{% endblock %}
