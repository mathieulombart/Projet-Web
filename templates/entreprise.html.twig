{% extends 'base.html.twig' %}

{% block title %}AlloStage – Offres postulées{% endblock %}

{% block styles %}
<style>
html {
  scroll-behavior: smooth;
}
body {
  background: #f8f9ff;
}

/* --- CARDS ENTREPRISES --- */
.company-card {
  border-radius: 20px;
  border: none;
  box-shadow: 0 4px 20px rgba(13, 110, 253, 0.09);
  background: #fff;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  overflow: hidden;
}
.company-card:hover {
  transform: translateY(-10px);
  box-shadow: 0 20px 40px rgba(13, 110, 253, 0.2);
}

/* Bandeau coloré en haut de la carte */
.card-banner {
  height: 72px;
  background: linear-gradient(135deg, #0d6efd 0%, #6ea8fe 100%);
}
.card-banner.green {
  background: linear-gradient(135deg, #198754, #75b798);
}
.card-banner.purple {
  background: linear-gradient(135deg, #6f42c1, #a98eda);
}
.card-banner.orange {
  background: linear-gradient(135deg, #fd7e14, #ffb974);
}
.card-banner.teal {
  background: linear-gradient(135deg, #0dcaf0, #6edff6);
}
.card-banner.red {
  background: linear-gradient(135deg, #dc3545, #f08080);
}

/* Tags secteur */
.tag {
  background: #e7f0ff;
  color: #0d6efd;
  border-radius: 20px;
  padding: 3px 12px;
  font-size: 0.76rem;
  font-weight: 600;
  display: inline-block;
}

/* Barre de recherche */
.search-bar {
  border-radius: 50px;
  border: 2px solid #dee2e6;
  padding: 10px 22px;
  font-size: 1rem;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.search-bar:focus {
  border-color: #0d6efd;
  box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.12);
  outline: none;
}

/* Filtre pills */
.filter-pill {
  border-radius: 50px;
  border: 2px solid #dee2e6;
  background: #fff;
  padding: 6px 18px;
  font-size: 0.85rem;
  font-weight: 600;
  color: #495057;
  cursor: pointer;
  transition: all 0.2s;
}
.filter-pill:hover,
.filter-pill.active {
  background: #0d6efd;
  border-color: #0d6efd;
  color: #fff;
}
</style>
{% endblock %}

{% block body %}



<!-- HERO -->
<section class="container text-center py-5">
  <h1 class="display-5 fw-semibold text-primary">
    Nos entreprises partenaires
  </h1>
  <p class="lead text-muted mt-2">
    Découvrez les entreprises qui recrutent des stagiaires et alternants.
  </p>
</section>

<!-- RECHERCHE + FILTRES -->
<section class="container mb-5">
  <div class="d-flex flex-column flex-md-row gap-3 align-items-center mb-3">
    <input
      type="text"
      class="search-bar flex-grow-1 w-100"
      placeholder="Rechercher une entreprise, un secteur…"
    />
    <a href="#" class="btn btn-primary rounded-pill px-4">Rechercher</a>
  </div>

  <div class="d-flex flex-wrap gap-2">
    <button class="filter-pill active">Tous</button>
    <button class="filter-pill">Tech & IT</button>
    <button class="filter-pill">Cybersécurité</button>
    <button class="filter-pill">Conseil</button>
    <button class="filter-pill">Industrie</button>
    <button class="filter-pill">Finance</button>
    <button class="filter-pill">Santé</button>
  </div>
</section>

<!-- GRILLE ENTREPRISES -->
<section class="container pb-5">
  <h2 class="text-primary fw-semibold mb-4">Entreprises récentes</h2>

  <div class="row g-4">

    <!-- Capgemini -->
