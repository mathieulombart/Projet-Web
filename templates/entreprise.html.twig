    <!-- Société Générale -->
    <div class="col-12 col-md-6 col-lg-4">
      <div class="company-card h-100">
        <div class="card-banner red"></div>
        <div class="p-4 pt-2">
          <h5 class="fw-bold mb-1">Société Générale</h5>
          <p class="text-muted small mb-2">
            📍 Paris · <span class="tag">Finance</span>
          </p>
          <p class="text-muted small mb-3">
