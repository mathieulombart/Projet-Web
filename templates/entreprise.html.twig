          </p>
          <div class="d-flex align-items-center justify-content-between">
            <span class="badge bg-primary rounded-pill">9 offres</span>
            <a href="#" class="btn btn-outline-primary btn-sm rounded-pill px-3">
              Voir les offres
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Doctolib -->
    <div class="col-12 col-md-6 col-lg-4">
      <div class="company-card h-100">
        <div class="card-banner teal"></div>
        <div class="p-4 pt-2">
          <h5 class="fw-bold mb-1">Doctolib</h5>
          <p class="text-muted small mb-2">
            📍 Paris · <span class="tag">Santé & Tech</span>
          </p>
          <p class="text-muted small mb-3">
