{% extends 'base.html.twig' %}

{% block title %}AlloStage – Wishlist{% endblock %}

{% block body %}

<section class="container text-center py-5">
  <h1 class="display-6 fw-semibold text-primary">Ma Wishlist</h1>
  <p class="text-muted">Les offres que vous avez mises de côté pour postuler plus tard.</p>
</section>

<section class="container pb-5">

  <div class="d-flex align-items-center justify-content-between mb-4">
    <span class="text-muted fw-semibold">2 offres sauvegardées</span>
  </div>

  <div class="d-flex flex-column gap-3">

    <!-- Offre 1 -->
    <div class="card border-0 shadow-sm rounded-4 p-4">
      <div class="d-flex align-items-center justify-content-between gap-3">
        <div class="flex-grow-1">
          <h5 class="fw-bold mb-1">Développeur Front-End</h5>
          <div class="d-flex align-items-center gap-2 flex-wrap">
            <span class="text-muted">📍 Paris</span>
            <span class="text-muted">·</span>
            <span class="text-muted">Société X</span>
            <span class="badge text-bg-primary rounded-pill">Stage 6 mois</span>
          </div>
        </div>
        <div class="d-flex flex-column align-items-end gap-2">
          <button class="btn btn-outline-danger btn-sm rounded-circle" title="Retirer de la wishlist">♥</button>
          <span class="badge bg-primary rounded-pill">En cours</span>
        </div>
      </div>
      <div class="mt-3">
        <a href="#" class="btn btn-sm btn-outline-primary rounded-pill">Voir l'offre</a>
      </div>
    </div>

    <!-- Offre 2 -->
    <div class="card border-0 shadow-sm rounded-4 p-4">
      <div class="d-flex align-items-center justify-content-between gap-3">
        <div class="flex-grow-1">
          <h5 class="fw-bold mb-1">Technicien Support</h5>
          <div class="d-flex align-items-center gap-2 flex-wrap">
            <span class="text-muted">📍 Nancy</span>
            <span class="text-muted">·</span>
            <span class="text-muted">Entreprise Y</span>
            <span class="badge text-bg-primary rounded-pill">Stage 3 mois</span>
          </div>
        </div>
        <div class="d-flex flex-column align-items-end gap-2">
          <button class="btn btn-outline-danger btn-sm rounded-circle" title="Retirer de la wishlist">♥</button>
          <span class="badge bg-success rounded-pill">Disponible</span>
        </div>
      </div>
      <div class="mt-3">
        <a href="#" class="btn btn-sm btn-outline-primary rounded-pill">Voir l'offre</a>
      </div>
    </div>

  </div>

  <div class="text-center mt-5">
    <a href="?page=profil" class="btn btn-outline-primary rounded-pill px-5">← Retour au profil</a>
  </div>

</section>

{% endblock %}
