{% extends 'base.html.twig' %}

{% block title %}AlloStage – Wishlist{% endblock %}

{% block styles %}
<style>
  html {
    scroll-behavior: smooth;
  }
  body {
    background: #f8f9ff;
  }

  .offer-card {
    border-radius: 20px;
    border: none;
    box-shadow: 0 4px 20px rgba(13, 110, 253, 0.09);
    background: #fff;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .offer-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 16px 40px rgba(13, 110, 253, 0.18);
    color: inherit;
  }

  .offer-icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: linear-gradient(135deg, #0d6efd 0%, #6ea8fe 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .heart-btn {
    border: none;
    background: #fff0f3;
    color: #dc3545;
    border-radius: 50%;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
  }
  .heart-btn:hover {
    background: #dc3545;
    color: #fff;
    transform: scale(1.1);
  }

  .tag {
    background: #e7f0ff;
    color: #0d6efd;
    border-radius: 20px;
    padding: 3px 12px;
    font-size: 0.78rem;
    font-weight: 600;
    display: inline-block;
  }
</style>
{% endblock %}

{% block body %}

<section class="container text-center py-5">
  <h1 class="display-6 fw-semibold text-primary">Ma Wishlist</h1>
  <p class="text-muted">Les offres que vous avez mises de côté pour postuler plus tard.</p>
</section>

<section class="container pb-5">

  <div class="d-flex align-items-center justify-content-between mb-4">
    <span class="text-muted fw-semibold">2 offres sauvegardées</span>
  </div>

  <div class="d-flex flex-column gap-3">

    <!-- Offre 1 -->
    <a href="#" class="offer-card card p-4">
      <div class="d-flex align-items-center justify-content-between gap-3">
        <div class="d-flex align-items-center gap-3 flex-grow-1">
          <div>
            <h5 class="fw-bold mb-1">Développeur Front-End</h5>
            <div class="d-flex align-items-center gap-2 flex-wrap">
              <span class="text-muted">📍 Paris</span>
              <span class="text-muted">·</span>
              <span class="text-muted">Société X</span>
              <span class="tag">Stage 6 mois</span>
            </div>
          </div>
        </div>

        <div class="d-flex flex-column align-items-end gap-2">
          <button class="heart-btn" title="Retirer de la wishlist">♥</button>
          <span class="badge bg-primary rounded-pill">En cours</span>
        </div>
      </div>
    </a>

    <!-- Offre 2 -->
    <a href="#" class="offer-card card p-4">
      <div class="d-flex align-items-center justify-content-between gap-3">
        <div class="d-flex align-items-center gap-3 flex-grow-1">
          <div>
            <h5 class="fw-bold mb-1">Technicien Support</h5>
            <div class="d-flex align-items-center gap-2 flex-wrap">
              <span class="text-muted">📍 Nancy</span>
              <span class="text-muted">·</span>
              <span class="text-muted">Entreprise Y</span>
              <span class="tag">Stage 3 mois</span>
            </div>
          </div>
        </div>

        <div class="d-flex flex-column align-items-end gap-2">
          <button class="heart-btn" title="Retirer de la wishlist">♥</button>
          <span class="badge bg-success rounded-pill">Disponible</span>
        </div>
      </div>
    </a>

  </div>

  <div class="text-center mt-5">
    <a href="/profil" class="btn btn-outline-primary rounded-pill px-5">← Retour au profil</a>
  </div>

</section>

{% endblock %}
