{% extends 'base.html.twig' %}

{% block title %}AlloStage – Wishlist{% endblock %}

{% block body %}

<section class="container text-center py-5">
  <h1 class="display-6 fw-semibold text-primary">Ma Wishlist</h1>
  <p class="text-muted">Les offres que vous avez mises de côté pour postuler plus tard.</p>
</section>

<section class="container pb-5">

  <div class="d-flex align-items-center justify-content-between mb-4">
    <span class="text-muted fw-semibold">{{ offres_wishlist|length }} offre{{ offres_wishlist|length > 1 ? 's' : '' }} sauvegardée{{ offres_wishlist|length > 1 ? 's' : '' }}</span>
  </div>

  <div class="d-flex flex-column gap-3">

    {% for offre in offres_wishlist %}
    <div class="card border-0 shadow-sm rounded-4 p-4">
      <div class="d-flex align-items-center justify-content-between gap-3">
        <div class="flex-grow-1">
          <h5 class="fw-bold mb-1">{{ offre.intitule }}</h5>
          <div class="d-flex align-items-center gap-2 flex-wrap">
            <span class="text-muted">📍 {{ offre.ville }}</span>
            <span class="text-muted">·</span>
            <span class="text-muted">{{ offre.entreprise }}</span>
            <span class="badge text-bg-primary rounded-pill">{{ offre.duree }}</span>
          </div>
        </div>
        <div class="d-flex flex-column align-items-end gap-2">
          <button class="btn btn-outline-danger btn-sm rounded-circle" title="Retirer de la wishlist">♥</button>
          <span class="badge bg-{{ offre.badge }} rounded-pill">{{ offre.statut }}</span>
        </div>
      </div>
      <div class="mt-3">
        <a href="#" class="btn btn-sm btn-outline-primary rounded-pill">Voir l'offre</a>
      </div>
    </div>
    {% endfor %}

  </div>

  <div class="text-center mt-5">
    <a href="?page=profil" class="btn btn-outline-primary rounded-pill px-5">← Retour au profil</a>
  </div>

</section>

{% endblock %}
