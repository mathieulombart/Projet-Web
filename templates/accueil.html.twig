{% extends 'base.html.twig' %}

{% block title %}AlloStage{% endblock %}

{% block body %}

<section class="container text-center py-5">
  <h1 class="display-5 fw-semibold text-primary">
    On connecte les meilleurs employeurs avec une jeunesse curieuse et engagée.
  </h1>
  <p class="lead mt-4">
    Que vous fassiez vos premiers pas dans le monde professionnel ou que vous cherchiez à renforcer vos équipes, Allostage est votre tremplin vers la réussite !
  </p>
</section>

<section class="container mb-5">
  <div class="d-flex flex-column flex-md-row gap-3 align-items-center mb-3">
    <input type="text" class="form-control rounded-pill px-4"
           placeholder="🔍 Rechercher une entreprise, un secteur…">
    <a href="#" class="btn btn-primary rounded-pill px-4">Rechercher</a>
  </div>
</section>

<section class="container py-5 text-center">
  <h2 class="mb-4 text-primary">Notre objectif ?</h2>
  <p class="mb-4">
    L'objectif principal d'Allostage est de mettre en relation les professionnels du monde entier pour les rendre plus performants et productifs.
  </p>
  <ul class="list-group list-group-flush">
    <li class="list-group-item">Connecter les talents entre étudiants et employeurs.</li>
    <li class="list-group-item">Démocratiser l'accès aux opportunités.</li>
    <li class="list-group-item">Valoriser les compétences des candidats.</li>
    <li class="list-group-item">Stimuler l'engagement entre jeunes et entreprises.</li>
  </ul>
</section>

<section class="container py-5">
  <h2 class="text-center mb-5 text-primary">Offres récentes</h2>
  <div class="row g-4">
    <div class="col-md-4">
      <div class="card h-100 shadow border-0 rounded-4">
        <img src="offre.jpg" class="card-img-top rounded-top-4" alt="Offre">
        <div class="card-body text-center">
          <h5 class="card-title">Offre spéciale 1</h5>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card h-100 shadow border-0 rounded-4">
        <img src="offre.jpg" class="card-img-top rounded-top-4" alt="Offre">
        <div class="card-body text-center">
          <h5 class="card-title">Offre spéciale 2</h5>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card h-100 shadow border-0 rounded-4">
        <img src="offre.jpg" class="card-img-top rounded-top-4" alt="Offre">
        <div class="card-body text-center">
          <h5 class="card-title">Offre spéciale 3</h5>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="container py-5">
  <h2 class="text-center mb-5 text-primary">Entreprises récentes</h2>
  <div class="row g-4">
    <div class="col-md-4">
      <div class="card shadow border-0 rounded-4 text-center">
        <img src="entreprise.jpg" class="card-img-top rounded-top-4" alt="Entreprise">
        <div class="card-body">
          <h5>Entreprise récente 1</h5>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card shadow border-0 rounded-4 text-center">
        <img src="entreprise.jpg" class="card-img-top rounded-top-4" alt="Entreprise">
        <div class="card-body">
          <h5>Entreprise récente 2</h5>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card shadow border-0 rounded-4 text-center">
        <img src="entreprise.jpg" class="card-img-top rounded-top-4" alt="Entreprise">
        <div class="card-body">
          <h5>Entreprise récente 3</h5>
        </div>
      </div>
    </div>
  </div>
</section>

<hr class="container">

<section class="container py-5">

  <div class="row align-items-center mb-5">
    <div class="col-md-6">
      <h2>Notre équipe sur votre projet</h2>
      <p>Je vous présente Mehefuz, ingénieur informatique spécialisé dans le développement web.</p>
    </div>
    <div class="col-md-6">
      <img src="personne.jpg" class="img-fluid rounded">
    </div>
  </div>

  <div class="row align-items-center bg-white rounded shadow-sm p-4 mb-5">
    <div class="col-md-6">
      <img src="personne.jpg" class="img-fluid rounded">
    </div>
    <div class="col-md-6">
      <h2>L'expertise visuelle</h2>
      <p>Sarah est notre designer UX/UI qui rend chaque interaction fluide.</p>
    </div>
  </div>

  <div class="row align-items-center mb-5">
    <div class="col-md-6">
      <h2>La force du Backend</h2>
      <p>Lucas assure la sécurité et la gestion des bases de données.</p>
    </div>
    <div class="col-md-6">
      <img src="personne.jpg" class="img-fluid rounded">
    </div>
  </div>

  <div class="row align-items-center bg-white rounded shadow-sm p-4">
    <div class="col-md-6">
      <img src="personne.jpg" class="img-fluid rounded">
    </div>
    <div class="col-md-6">
      <h2>Coordination et stratégie</h2>
      <p>Emma coordonne toute l'équipe pour garantir la qualité du projet.</p>
    </div>
  </div>

</section>

{% endblock %}
