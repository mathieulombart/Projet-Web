{% extends 'base.html.twig' %}

{% block title %}AlloStage – Profil{% endblock %}

{% block body %}

<section class="container text-center py-5">
  <h1 class="display-6 fw-semibold text-primary">Mon Profil</h1>
  <p class="text-muted">Gérez vos informations personnelles et suivez vos candidatures.</p>
</section>

<section class="container pb-5">
  <div class="row g-4">

    <!-- COLONNE GAUCHE -->
    <div class="col-12 col-lg-8">
      <div class="card border-0 shadow-sm rounded-4 p-4">
        <div class="d-flex align-items-center mb-4">
          <div>
            <h2 class="fw-bold mb-1">{{ utilisateur.nom }}</h2>
            <span class="badge text-bg-primary rounded-pill px-3 py-2">{{ utilisateur.statut }}</span>
          </div>
        </div>

        <hr class="my-3">

        <div class="list-group list-group-flush">

          <div class="list-group-item px-0 d-flex align-items-center gap-3 border-0 border-bottom py-3">
            <span class="badge bg-primary-subtle text-primary fs-5 rounded-3 p-2">🏫</span>
            <div>
              <small class="text-muted d-block">École</small>
              <strong>{{ utilisateur.ecole }}</strong>
            </div>
          </div>

          <div class="list-group-item px-0 d-flex align-items-center gap-3 border-0 border-bottom py-3">
            <span class="badge bg-primary-subtle text-primary fs-5 rounded-3 p-2">👩‍🏫</span>
            <div>
              <small class="text-muted d-block">Pilote</small>
              <strong>{{ utilisateur.pilote }}</strong>
            </div>
          </div>

          <div class="list-group-item px-0 d-flex align-items-center gap-3 border-0 border-bottom py-3">
            <span class="badge bg-primary-subtle text-primary fs-5 rounded-3 p-2">✉️</span>
            <div>
              <small class="text-muted d-block">Email</small>
              <strong>{{ utilisateur.email }}</strong>
            </div>
          </div>

          <div class="list-group-item px-0 d-flex align-items-center gap-3 border-0 py-3">
            <span class="badge bg-primary-subtle text-primary fs-5 rounded-3 p-2">📍</span>
            <div>
              <small class="text-muted d-block">Ville d'étude</small>
              <strong>{{ utilisateur.ville }}</strong>
            </div>
          </div>

        </div>

        <hr class="my-4">

        <div class="d-flex gap-2 flex-wrap">
          <a href="#" class="btn btn-primary rounded-pill px-4">Modifier le profil</a>
        </div>
      </div>
    </div>

    <!-- COLONNE DROITE -->
    <div class="col-12 col-lg-4 d-flex flex-column gap-3">

      <a href="?page=wishlist" class="card border-0 shadow-sm rounded-4 p-4 text-decoration-none text-dark">
        <div class="d-flex align-items-center gap-3">
          <span class="fs-2">❤️</span>
          <div>
            <h5 class="fw-bold mb-0 text-primary">Wishlist</h5>
            <small class="text-muted">Mes offres favorites</small>
          </div>
        </div>
        <div class="mt-3">
          <span class="badge bg-primary rounded-pill">2 offres</span>
        </div>
      </a>

      <a href="?page=offres_postulees" class="card border-0 shadow-sm rounded-4 p-4 text-decoration-none text-dark">
        <div class="d-flex align-items-center gap-3">
          <span class="fs-2">📋</span>
          <div>
            <h5 class="fw-bold mb-0 text-primary">Offres postulées</h5>
            <small class="text-muted">Mes candidatures en cours</small>
          </div>
        </div>
        <div class="mt-3">
          <span class="badge bg-success rounded-pill">2 candidatures</span>
        </div>
      </a>

    </div>

  </div>
</section>

{% endblock %}
