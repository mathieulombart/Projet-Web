{% extends 'base.html.twig' %}

{% block title %}AlloStage – Profil{% endblock %}

{% block styles %}
<style>
  html { scroll-behavior: smooth; }
  body { background: #f8f9ff; }

  .profile-card {
    border-radius: 20px;
    border: none;
    box-shadow: 0 8px 32px rgba(13, 110, 253, 0.1);
    background: #fff;
  }

  .info-row {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 11px 0;
    border-bottom: 1px solid #f0f1f7;
  }
  .info-row:last-child {
    border-bottom: none;
  }

  .info-icon {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    background: #e7f0ff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .side-card {
    border-radius: 18px;
    border: none;
    box-shadow: 0 4px 20px rgba(13, 110, 253, 0.09);
    background: #fff;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .side-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 14px 36px rgba(13, 110, 253, 0.18);
    color: inherit;
  }

  .badge-statut {
    background: #e7f0ff;
    color: #0d6efd;
    border-radius: 20px;
    padding: 4px 14px;
    font-size: 0.82rem;
    font-weight: 600;
    display: inline-block;
  }
</style>
{% endblock %}

{% block body %}

<section class="container text-center py-5">
  <h1 class="display-6 fw-semibold text-primary">Mon Profil</h1>
  <p class="text-muted">Gérez vos informations personnelles et suivez vos candidatures.</p>
</section>

<section class="container pb-5">
  <div class="row g-4">

    <!-- COLONNE GAUCHE -->
    <div class="col-12 col-lg-8">
      <div class="profile-card card p-4">
        <div class="d-flex align-items-center mb-4">
          <div>
            <h2 class="fw-bold mb-1">Nom Prénom</h2>
            <span class="badge-statut">Étudiant – A2</span>
          </div>
        </div>

        <hr class="my-3">

        <div>
          <div class="info-row">
            <div class="info-icon">🏫</div>
            <div>
              <small class="text-muted d-block">École</small>
              <strong>CESI</strong>
            </div>
          </div>

          <div class="info-row">
            <div class="info-icon">👩‍🏫</div>
            <div>
              <small class="text-muted d-block">Pilote</small>
              <strong>Dupont Marie</strong>
            </div>
          </div>

          <div class="info-row">
            <div class="info-icon">✉️</div>
            <div>
              <small class="text-muted d-block">Email</small>
              <strong>etudiant@cesi.fr</strong>
            </div>
          </div>

          <div class="info-row">
            <div class="info-icon">📍</div>
            <div>
              <small class="text-muted d-block">Ville d'étude</small>
              <strong>Nancy</strong>
            </div>
          </div>
        </div>

        <hr class="my-4">

        <div class="d-flex gap-2 flex-wrap">
          <a href="#" class="btn btn-primary rounded-pill px-4">Modifier le profil</a>
        </div>
      </div>
    </div>

    <!-- COLONNE DROITE -->
    <div class="col-12 col-lg-4 d-flex flex-column gap-3">

      <a href="?page=wishlist" class="side-card card p-4">
        <div class="d-flex align-items-center gap-3">
          <span style="font-size: 2rem">❤️</span>
          <div>
            <h5 class="fw-bold mb-0 text-primary">Wishlist</h5>
            <small class="text-muted">Mes offres favorites</small>
          </div>
        </div>
        <div class="mt-3">
          <span class="badge bg-primary rounded-pill">2 offres</span>
        </div>
      </a>

      <a href="?page=offres_postulees" class="side-card card p-4">
        <div class="d-flex align-items-center gap-3">
          <span style="font-size: 2rem">📋</span>
          <div>
            <h5 class="fw-bold mb-0 text-primary">Offres postulées</h5>
            <small class="text-muted">Mes candidatures en cours</small>
          </div>
        </div>
        <div class="mt-3">
          <span class="badge bg-success rounded-pill">2 candidatures</span>
        </div>
      </a>

    </div>

  </div>
</section>

{% endblock %}
