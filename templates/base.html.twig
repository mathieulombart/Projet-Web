<!doctype html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>{% block title %}AlloStage{% endblock %}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    {% block styles %}{% endblock %}
</head>

<body>

<header class="border-bottom bg-white">
  <div class="container py-3 d-flex justify-content-between align-items-center">
    <img src="Allostage.png" alt="Logo AlloStage" width="180">

    <ul class="nav">
      <li class="nav-item">
        <a class="nav-link fw-bold text-primary" href="?page=accueil">Accueil</a>
      </li>
      <li class="nav-item">
        <a class="nav-link fw-bold text-primary" href="?page=entreprise">Entreprises</a>
      </li>
      <li class="nav-item">
        <a class="nav-link fw-bold text-primary" href="?page=offres">Offres</a>
      </li>
      <li class="nav-item">
        <a class="nav-link fw-bold text-primary" href="?page=profil">Profil</a>
      </li>
    </ul>
  </div>
</header>



{% block body %}{% endblock %}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<footer class="bg-dark text-white text-center py-4 mt-5">
    <div class="container">
        <p class="mb-1">© 2026 AlloStage</p>
        <p class="mb-2">Connecter les étudiants et les entreprises pour construire l'avenir.</p>

        <div class="d-flex justify-content-center gap-3">
            <a href="#" class="text-white-50 text-decoration-none">Mentions légales</a>
            <a href="#" class="text-white-50 text-decoration-none">Contact</a>
            <a href="#" class="text-white-50 text-decoration-none">Confidentialité</a>
        </div>
    </div>
</footer>

</body>
</html>
